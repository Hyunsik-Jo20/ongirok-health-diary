# 이 파일을 .env로 복사한 뒤 실제 키를 입력하세요.
# .env는 외부에 공유하거나 Git에 올리지 마세요.

OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_URL=https://api.openai.com/v1/responses
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash

# Supabase 로그인/승인제
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DAILY_AI_LIMIT=2
PROFILE_MONTHLY_LIMIT=1
MAX_IMAGES_PER_REQUEST=5
MAX_UPLOAD_FILE_MB=8
MAX_UPLOAD_PDF_MB=5

# Supabase를 쓰지 않는 로컬 테스트용 공유 코드
# APP_ACCESS_CODE=change-this-share-code

# 사용하려는 공공데이터 날씨 API에 맞게 설정하세요.
WEATHER_API_KEY=your-weather-service-key
WEATHER_API_URL=https://apis.data.go.kr/1360000/VilageFcstInfoService_2.0/getUltraSrtNcst
WEATHER_API_KEY_PARAM=serviceKey

# API에 항상 필요한 쿼리 파라미터가 있다면 URL 쿼리 형식으로 작성합니다.
WEATHER_DEFAULT_PARAMS=dataType=JSON&numOfRows=1000&pageNo=1

# 키를 쿼리 대신 헤더로 보내는 API만 사용합니다.
# WEATHER_AUTH_HEADER=Authorization
# WEATHER_AUTH_PREFIX=Bearer 
